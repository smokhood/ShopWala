rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isShopOwner(shopOwnerId) {
      return isAuthenticated() && request.auth.uid == shopOwnerId;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can only read/write their own data
      allow read, write: if isOwner(userId);
    }
    
    // Shops collection
    match /shops/{shopId} {
      // Anyone can read active shops
      allow read: if resource.data.isActive == true;
      
      // Only shop owner can write
      allow create: if isAuthenticated();
      allow update, delete: if isShopOwner(resource.data.ownerId);
      
      // Validate shop data on write
      allow write: if request.resource.data.keys().hasAll([
        'name', 'ownerName', 'ownerId', 'category', 'whatsapp',
        'location', 'isOpen', 'hours', 'isActive'
      ]);
    }
    
    // Products collection
    match /products/{productId} {
      // Get shop owner from shop document
      function getShopOwnerId() {
        return get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId;
      }

      // Customers can only submit stock flags (no pricing/name/shop edits)
      function canCustomerFlagStock() {
        let changed = request.resource.data.diff(resource.data).changedKeys();
        return isAuthenticated()
          && changed.hasOnly(['flagCount', 'stockStatus', 'updatedAt'])
          && request.resource.data.flagCount == resource.data.flagCount + 1
          && (!changed.hasAny(['stockStatus']) || request.resource.data.stockStatus == 'unverified');
      }
      
      // Anyone can read active products
      // Shop owners can read all their own products (active or inactive)
      allow read: if resource.data.isActive == true || (isAuthenticated() && isShopOwner(getShopOwnerId()));
      
      // Only shop owner can write products
      allow create: if isAuthenticated();
      allow update: if isShopOwner(getShopOwnerId()) || canCustomerFlagStock();
      allow delete: if isShopOwner(getShopOwnerId());
      
      // Validate product data
      allow write: if request.resource.data.keys().hasAll([
        'shopId', 'name', 'category', 'price', 'unit', 'inStock', 'isActive'
      ]) && request.resource.data.price > 0;
    }
    
    // Deals collection
    match /deals/{dealId} {
      // Anyone can read active deals
      // Expiry is filtered in app queries to avoid request.time query-rule mismatch
      allow read: if resource.data.isActive == true;
      
      // Get shop owner from shop document
      function getDealShopOwnerId() {
        return get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId;
      }
      
      // Only shop owner can write deals
      allow create: if isAuthenticated();
      allow update, delete: if isShopOwner(getDealShopOwnerId());
      
      // Validate deal data
      allow write: if request.resource.data.keys().hasAll([
        'shopId', 'shopName', 'productName', 'originalPrice', 'dealPrice'
      ]) && request.resource.data.dealPrice < request.resource.data.originalPrice;
    }
    
    // Searches collection (for demand tracking)
    match /searches/{searchId} {
      // Authenticated users can read searches
      // Shop owners will filter by their shopId in the app layer
      allow read: if isAuthenticated();
      
      // Authenticated users can create search records
      allow create: if isAuthenticated();
      
      // No updates or deletes
      allow update, delete: if false;
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Notifications are created by backend (Admin SDK bypasses rules)
      allow create: if false;
      
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Users can delete their own notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Orders collection
    match /orders/{orderId} {
      // Resolve current user's shopId once for owner checks
      function currentUserShopId() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId;
      }

      function customerCanMarkCompleted() {
        let changed = request.resource.data.diff(resource.data).changedKeys();
        return resource.data.customerId == request.auth.uid
          && resource.data.status == 'dispatched'
          && request.resource.data.status == 'completed'
          && changed.hasOnly(['status', 'completedAt', 'updatedAt']);
      }

      // Customers can read their own orders
      // Shop owners can read orders for their own shop
      allow read: if isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.shopId == currentUserShopId()
      );

      // Authenticated customers can create orders
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;

      // Shop owners can update orders of their own shop (status, notes, etc.)
      // Customers can update their own orders (mark as completed)
      allow update: if isAuthenticated() && (
        resource.data.shopId == currentUserShopId() ||
        customerCanMarkCompleted()
      );

      // No deletes
      allow delete: if false;
    }
    
    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
